# Environment Configuration
# Copy this file to .env and customize

# API URL - Backend server address
# Development: http://127.0.0.1:8000
# Production: https://api.university.uz
API_URL=https://map.ranch.university/api

# Kiosk Mode - Enable true kiosk behavior
# true: fullscreen, no menu, no exit
# false: normal window mode
KIOSK_MODE=false

# Auto Fullscreen - Start in fullscreen
AUTO_FULLSCREEN=false

# Idle Timeout (milliseconds)
# 300000 = 5 minutes
IDLE_TIMEOUT_MS=300000

# Animation Loops - How many times to repeat path animation
ANIMATION_LOOPS=3

# Debug Mode - Show DevTools
DEBUG_MODE=false

# Security: only enable for trusted internal/self-signed environments
ALLOW_INSECURE_TLS=false

# Security: disable admin quit/reset shortcuts in kiosk by default
ADMIN_SHORTCUTS_ENABLED=false
